# Local/demo placeholder environment.
# Do not use this file as a production secret source or commit a real `.env`.
# Production deployments must inject secrets from a secret manager or platform environment.

APP_ENVIRONMENT=local
PAYMENT_PROVIDER_ACTIVE=fake
PAYMENT_PROVIDER_ENABLED=fake
AUTHENTICATION_PROVIDER=keycloak
# Local placeholder only; prod requires a high-entropy value outside the database.
AUDIT_SIGNATURE_SECRET=local-audit-signature-secret
AUDIT_HASH_VERIFICATION_BATCH_SIZE=500
# Local placeholder only.
FAKE_PROVIDER_WEBHOOK_SECRET=local-fake-webhook-secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=
STRIPE_CONNECT_TIMEOUT_MS=2000
STRIPE_READ_TIMEOUT_MS=5000
PAYMENT_IDEMPOTENCY_IN_PROGRESS_LEASE_SECONDS=300
RECONCILIATION_BATCH_SIZE=500
RECONCILIATION_MAX_ISSUES_PER_RUN=1000
STOCK_STREAM_MAX_CONNECTIONS_PER_CLIENT=3
STOCK_STREAM_TIMEOUT_SECONDS=300
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=in-memory
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SENSITIVE_REQUESTS_PER_WINDOW=30
RATE_LIMIT_WEBHOOK_REQUESTS_PER_WINDOW=120
RATE_LIMIT_PROFILE_REQUESTS_PER_WINDOW=60
RATE_LIMIT_MAX_KEYS=10000
REQUEST_MAX_JSON_BODY_BYTES=32768
WEBHOOK_MAX_BODY_BYTES=65536
TRUSTED_PROXY_CIDRS=
OPENAPI_PUBLIC_DOCS_ENABLED=true
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
OAUTH2_JWK_SET_URI=http://localhost:8081/realms/ecommerce/protocol/openid-connect/certs
OAUTH2_ISSUER_URI=http://localhost:8081/realms/ecommerce
OAUTH2_REQUIRED_AUDIENCE=ecommerce-api
OAUTH2_RESOURCE_CLIENT_ID=ecommerce-api
# Required in prod so JWT azp/client binding is enforced.
OAUTH2_ALLOWED_AUTHORIZED_PARTIES=ecommerce-web

ECOMMERCE_DB_URL=jdbc:postgresql://localhost:5433/ecommerce
ECOMMERCE_DB_USERNAME=ecommerce_app
# Local placeholder only.
ECOMMERCE_DB_PASSWORD=ecommerce_app_password

TEST_DB_URL=jdbc:postgresql://localhost:5433/ecommerce_test
TEST_DB_USERNAME=ecommerce_app
# Local placeholder only.
TEST_DB_PASSWORD=ecommerce_app_password

POSTGRES_HOST_PORT=5433
KEYCLOAK_HOST_PORT=8081
KEYCLOAK_MANAGEMENT_HOST_PORT=9001
# Local Keycloak admin placeholders only.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
